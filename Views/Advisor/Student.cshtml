@model StudentTrackingCoach.Models.ViewModels.AdvisorStudentDetailViewModel

@{
    ViewData["Title"] = "Student Advisory Review";
    var coursesVm = ViewBag.StudentCourses as StudentTrackingCoach.Models.ViewModels.StudentCoursesViewModel;
    var passingThreshold = (decimal)(ViewBag.PassingThreshold ?? 70m);
    var aiRecommendation = ViewBag.AiRecommendation as StudentTrackingCoach.Models.Ai.AiRecommendationResult;
    var showConfidenceScore = (bool)(ViewBag.ShowConfidenceScore ?? false);
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h2 class="mb-1">@Model.StudentName</h2>
        <div class="text-muted">
            Student ID: <strong>@Model.StudentId</strong>
            @if (!string.IsNullOrWhiteSpace(Model.EnrollmentStatus))
            {
                <span class="ms-3">Status: <strong>@Model.EnrollmentStatus</strong></span>
            }
        </div>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">
        ← Back to Dashboard
    </a>
</div>

<!-- ========================= -->
<!-- RISK SUMMARY -->
<!-- ========================= -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-center">
            <div class="col-md-3">
                <div class="text-muted mb-1">Risk Level</div>
                <span class="badge @(Model.RiskLevel == "High" ? "bg-danger" :
                                                            Model.RiskLevel == "Medium" ? "bg-warning text-dark" :
                                                            "bg-success")">
                    @Model.RiskLevel
                </span>
            </div>

            <div class="col-md-3">
                <div class="text-muted mb-1">Average Score</div>
                <div class="fw-semibold">@Model.AverageScore.ToString("0.0")</div>
            </div>

            <div class="col-md-3">
                <div class="text-muted mb-1">Primary Risk Driver</div>
                <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(Model.PrimaryRiskDriver) ? Model.PrimaryRiskDriver : "—")</div>
            </div>

            <div class="col-md-3">
                <div class="text-muted mb-1">Recommended Action</div>
                <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(Model.SecondaryRiskDriver) ? Model.SecondaryRiskDriver : "—")</div>
            </div>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

<!-- ========================= -->
<!-- AI SUMMARY SIDEBAR -->
<!-- ========================= -->
<div class="card shadow-sm mb-4 border-primary">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <h5 class="mb-0">🤖 AI Recommendation Summary</h5>
        <a asp-action="Student"
           asp-route-id="@Model.StudentId"
           asp-route-regenerateAi="true"
           class="btn btn-sm btn-outline-primary">
            Regenerate AI Recommendations
        </a>
    </div>
    <div class="card-body">
        @if (aiRecommendation == null)
        {
            <p class="text-muted mb-0"><em>No AI recommendation available.</em></p>
        }
        else
        {
            <div class="mb-2"><strong>Focus Areas:</strong> @aiRecommendation.FocusAreas</div>
            <div class="mb-2"><strong>Schedule:</strong> @aiRecommendation.StudySchedule</div>
            <div class="mb-2"><strong>Techniques:</strong> @aiRecommendation.StudyTechniques</div>
            <div class="mb-2"><strong>Expected Outcome:</strong> @aiRecommendation.ExpectedOutcome</div>
            @if (showConfidenceScore && aiRecommendation.ConfidenceScore.HasValue)
            {
                <span class="badge bg-secondary">Confidence: @((aiRecommendation.ConfidenceScore.Value * 100).ToString("0"))%</span>
            }
        }
    </div>
</div>

<!-- ========================= -->
<!-- CURRENT COURSES & GRADES -->
<!-- ========================= -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <h5 class="mb-0">Current Courses &amp; Grades</h5>
            <span class="badge bg-light text-dark">
                Term Average: @(coursesVm?.CurrentTermAverage.ToString("0.0") ?? "0.0")%
            </span>
        </div>

        @if (coursesVm == null || coursesVm.Courses == null || !coursesVm.Courses.Any())
        {
            <p class="text-muted mb-0"><em>No current-term course grade data available.</em></p>
        }
        else
        {
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Course Code</th>
                        <th>Course Name</th>
                        <th>Current Grade</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in coursesVm.Courses)
                    {
                        var gradeClass = course.CurrentGrade >= passingThreshold
                            ? "text-success fw-semibold"
                            : course.CurrentGrade >= 60m
                                ? "text-warning fw-semibold"
                                : "text-danger fw-semibold";

                        var status = course.CurrentGrade >= passingThreshold ? "Passing" : "Failing";
                        var statusBadge = course.CurrentGrade >= passingThreshold
                            ? "badge bg-success"
                            : course.CurrentGrade >= 60m
                                ? "badge bg-warning text-dark"
                                : "badge bg-danger";

                        <tr>
                            <td>@course.CourseCode</td>
                            <td>@course.CourseName</td>
                            <td class="@gradeClass">@course.CurrentGrade.ToString("0.0")%</td>
                            <td><span class="@statusBadge">@status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@if (Model.RiskLevel == "High" || Model.RiskLevel == "Medium")
{
    <div class="mt-3 mb-4">
        <a asp-controller="Students"
           asp-action="RecommendedStudyGuide"
           asp-route-id="@Model.StudentId"
           class="btn btn-primary btn-lg">
            📚 Create Study Guide
        </a>
        <small class="text-muted ms-2">
            Generate personalized study recommendations
        </small>
    </div>
}

<!-- ========================= -->
<!-- ADVISOR NOTES TIMELINE -->
<!-- ========================= -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <h5 class="mb-0">Advisor Notes (Latest First)</h5>
            <span class="badge bg-light text-dark">
                Total Notes: @Model.Notes.Count
            </span>
        </div>

        @if (Model.Notes == null || !Model.Notes.Any())
        {
            <p class="text-muted mb-0"><em>No advisor notes yet for this student.</em></p>
        }
        else
        {
            <div class="list-group">
                @foreach (var note in Model.Notes.OrderByDescending(n => n.CreatedAt))
                {
                    var badge = note.Severity switch
                    {
                        "High" => "bg-danger",
                        "Medium" => "bg-warning text-dark",
                        _ => "bg-success"
                    };

                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="me-3">
                                <div class="fw-semibold">@note.Title</div>
                                <div class="text-muted small">
                                    @note.CreatedAt.ToString("MM/dd/yyyy") • @note.CreatedBy
                                </div>
                            </div>
                            <span class="badge @badge">@note.Severity</span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(note.Notes))
                        {
                            <div class="mt-2">@note.Notes</div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- ========================= -->
<!-- ADD NEW NOTE -->
<!-- ========================= -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="mb-3">Add New Advisor Note</h5>

        <form asp-action="AddNote" method="post">
            <input type="hidden" name="StudentId" value="@Model.StudentId" />

            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Title</label>
                    <input class="form-control" name="Title" maxlength="120" required />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Severity</label>
                    <select class="form-select" name="Severity" required>
                        <option value="Low">Low</option>
                        <option value="Medium">Medium</option>
                        <option value="High">High</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Category</label>
                    <select class="form-select" name="Category" required>
                        <option value="Academic">Academic</option>
                        <option value="Attendance">Attendance</option>
                        <option value="Behavior">Behavior</option>
                        <option value="Engagement">Engagement</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <div class="col-12">
                    <label class="form-label">Note</label>
                    <textarea class="form-control" name="Note" rows="4" placeholder="Write advisor note here..."></textarea>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">
                    Save Note
                </button>
                <span class="text-muted ms-2 small">
                    (This is presentation-ready — we can persist to DB next.)
                </span>
            </div>
        </form>
    </div>
</div>

<!-- ========================= -->
<!-- OPTIONAL: ADVISOR ACTION LOG (PHASE 2 READY) -->
<!-- ========================= -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="mb-3">Advisor Action (Optional)</h5>

        <form asp-action="LogDecision" method="post">
            <input type="hidden" name="StudentId" value="@Model.StudentId" />

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Action Taken</label>
                    <select class="form-select" name="ActionTaken" required>
                        <option value="">-- Select Action --</option>
                        <option>Reached out to student</option>
                        <option>Scheduled advising meeting</option>
                        <option>Referred to tutoring services</option>
                        <option>Escalated to academic support</option>
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Notes (optional)</label>
                    <input class="form-control" name="Notes" maxlength="250" />
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-success">
                    Save Advisor Action
                </button>
            </div>
        </form>

        @if (!string.IsNullOrWhiteSpace(ViewBag.Narrative as string))
        {
            <div class="alert alert-info mt-3 mb-0">
                @ViewBag.Narrative
            </div>
        }
    </div>
</div>
