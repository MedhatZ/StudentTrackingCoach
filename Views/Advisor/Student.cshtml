@model StudentTrackingCoach.Models.AdvisorRiskDashboardDto

@{
    ViewData["Title"] = "Student Risk Detail";
}

<h2>@Model.FirstName @Model.LastName</h2>

<hr />

<div class="mb-3">
    <strong>Risk Level:</strong>
    <span class="badge @(Model.RiskLevel == "High" ? "bg-danger" :
                                    Model.RiskLevel == "Medium" ? "bg-warning text-dark" :
                                    "bg-success")">
        @Model.RiskLevel
    </span>
</div>

<div class="mb-3">
    <strong>Average Score:</strong> @Model.AverageScore
</div>

<div class="mb-3">
    <strong>Primary Risk Driver:</strong>
    <p>@Model.PrimaryRiskDriver</p>
</div>

<div class="mb-3">
    <strong>Recommended Action:</strong>
    <p>@Model.SecondaryRiskDriver</p>
</div>

<hr />

<h4>Advisor Narrative</h4>
<hr />

<h4>Advisor Action</h4>

<form asp-action="LogDecision" method="post">
    <input type="hidden" name="StudentId" value="@Model.StudentID" />

    <div class="mb-3">
        <label class="form-label">Action Taken</label>
        <select class="form-select" name="ActionTaken" required>
            <option value="">-- Select Action --</option>
            <option>Reached out to student</option>
            <option>Scheduled advising meeting</option>
            <option>Referred to tutoring services</option>
            <option>Escalated to academic support</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Notes</label>
        <textarea class="form-control" name="Notes" rows="3"></textarea>
    </div>

    <button type="submit" class="btn btn-success">
        Save Advisor Action
    </button>
</form>

<p>@ViewBag.Narrative</p>

<a asp-action="Index" class="btn btn-secondary mt-3">
    Back to Dashboard
</a>
