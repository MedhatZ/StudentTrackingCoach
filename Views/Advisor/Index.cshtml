@model IEnumerable<StudentTrackingCoach.Models.AdvisorRiskDashboardDto>

@{
    ViewData["Title"] = "Advisor Dashboard";
}

<h2 class="mb-4">Advisor Dashboard</h2>

<!-- STUDENTS REQUIRING ATTENTION -->
<div class="card shadow-sm">
    <div class="card-body">
        <h5 class="mb-3">Students Requiring Attention</h5>

        @if (!Model.Any())
        {
            <p class="text-muted">
                <em>No students currently require attention.</em>
            </p>
        }
        else
        {
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Student</th>
                        <th>Risk Level</th>
                        <th>Average Score</th>
                        <th>Why</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in Model)
                    {
                        string badgeClass = student.RiskLevel switch
                        {
                            "High" => "badge bg-danger",
                            "Medium" => "badge bg-warning text-dark",
                            _ => "badge bg-success"
                        };

                        <tr>
                            <td>
                                <a asp-controller="Advisor"
                                   asp-action="Student"
                                   asp-route-id="@student.StudentId">
                                    @student.FirstName @student.LastName
                                </a>
                            </td>

                            <td>
                                <span class="@badgeClass">
                                    @student.RiskLevel
                                </span>
                            </td>

                            <td>
                                @student.AverageScore
                            </td>

                            <td>
                                @student.PrimaryRiskDriver
                            </td>

                            <td>
                                @student.SecondaryRiskDriver
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
