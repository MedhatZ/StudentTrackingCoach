@model List<StudentTrackingCoach.Models.Intervention>

<h2>Pending Study Guide Reviews</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No pending study guides to review.
    </div>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Student</th>
                <th>Created</th>
                <th>Type</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.OrderByDescending(i => i.CreatedAt))
            {
                <tr>
                    <td>@item.StudentName</td>
                    <td>@item.CreatedAt.ToString("MM/dd/yyyy HH:mm")</td>
                    <td>@item.Type</td>
                    <td>
                        <span class="badge bg-warning">@item.Status</span>
                    </td>
                    <td>
                        <a asp-action="ReviewStudyGuide"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-primary">
                            Review
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
