@model List<StudentTrackingCoach.Models.Tenant>

@{
    ViewData["Title"] = "Tenants";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Tenant Management</h2>
    <a asp-action="CreateTenant" class="btn btn-primary">Create Tenant</a>
</div>

@if (TempData["SuccessMessage"] is string message)
{
    <div class="alert alert-success">@message</div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Tenant ID</th>
            <th>Name</th>
            <th>Slug</th>
            <th>Status</th>
            <th>Passing Grade</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var tenant in Model)
    {
        <tr>
            <td>@tenant.TenantId</td>
            <td>@tenant.Name</td>
            <td>@tenant.Slug</td>
            <td>@(tenant.IsActive ? "Active" : "Disabled")</td>
            <td>@tenant.PassingGrade</td>
            <td class="text-end">
                <a asp-action="TenantDetails" asp-route-id="@tenant.TenantId" class="btn btn-sm btn-outline-primary">Details</a>
                <form asp-action="SwitchTenant" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="tenantId" value="@tenant.TenantId" />
                    <button type="submit" class="btn btn-sm btn-outline-secondary">Switch</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
