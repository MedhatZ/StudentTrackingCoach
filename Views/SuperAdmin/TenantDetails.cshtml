@model StudentTrackingCoach.Models.Tenant

@{
    ViewData["Title"] = "Tenant Details";
    var usage = ViewBag.Usage as Dictionary<string, int> ?? new Dictionary<string, int>();
}

<h2>Tenant Details</h2>

@if (TempData["SuccessMessage"] is string message)
{
    <div class="alert alert-success">@message</div>
}

<form asp-action="TenantDetails" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="TenantId" />
    <input type="hidden" asp-for="CreatedAt" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Slug" class="form-label"></label>
        <input asp-for="Slug" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="ConnectionString" class="form-label"></label>
        <input asp-for="ConnectionString" class="form-control" />
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="PassingGrade" class="form-label"></label>
            <input asp-for="PassingGrade" class="form-control" />
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="HighRiskThreshold" class="form-label"></label>
            <input asp-for="HighRiskThreshold" class="form-control" />
        </div>
    </div>
    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Tenants" class="btn btn-link">Back</a>
</form>

<hr />
<h4>Usage Metrics</h4>
<ul>
@foreach (var metric in usage)
{
    <li><strong>@metric.Key:</strong> @metric.Value</li>
}
</ul>
