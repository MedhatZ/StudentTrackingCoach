@model List<StudentTrackingCoach.Models.ViewModels.RecommendedStudyGuideViewModel>
@{
    ViewData["Title"] = "My Study Guides";
    var guideDebug = ViewBag.GuideDebug as List<StudentTrackingCoach.Models.ViewModels.StudyGuideDebugInfoViewModel>
        ?? new List<StudentTrackingCoach.Models.ViewModels.StudyGuideDebugInfoViewModel>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">My Study Guides</h2>
    <span class="badge bg-success fs-6">Approved: @ViewBag.ApprovedCount</span>
</div>

@if (!string.IsNullOrWhiteSpace(ViewBag.ErrorMessage))
{
    <div class="alert alert-warning">
        @ViewBag.ErrorMessage
    </div>
}

@if (!Model.Any())
{
    @if (string.IsNullOrWhiteSpace(ViewBag.ErrorMessage))
    {
        <div class="alert alert-warning">
            No approved study guides found.
        </div>
    }
}
else
{
    foreach (var guide in Model)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Study Guide</h5>
            </div>
            <div class="card-body">
                <h6>🎯 Focus Areas</h6>
                <p>
                    @Html.Raw((string.IsNullOrWhiteSpace(guide.FocusAreas) ? "No focus areas available." : guide.FocusAreas).Replace("\n", "<br />"))
                </p>
                
                <h6>📅 Schedule</h6>
                <p>
                    @Html.Raw((string.IsNullOrWhiteSpace(guide.StudySchedule) ? "No schedule available." : guide.StudySchedule).Replace("\n", "<br />"))
                </p>
                
                <h6>📚 Techniques</h6>
                <p>
                    @Html.Raw((string.IsNullOrWhiteSpace(guide.StudyTechniques) ? "No study techniques available." : guide.StudyTechniques).Replace("\n", "<br />"))
                </p>

                <h6>📎 Resources</h6>
                <p>
                    @Html.Raw((string.IsNullOrWhiteSpace(guide.Resources) ? "No resources listed." : guide.Resources).Replace("\n", "<br />"))
                </p>

                @if (guide.FollowUpDate.HasValue)
                {
                    <div class="alert alert-light mb-0 mt-3">
                        <strong>Follow-up date:</strong> @guide.FollowUpDate.Value.ToString("MMM dd, yyyy")
                    </div>
                }
                else
                {
                    <div class="alert alert-light mb-0 mt-3">
                        <strong>Follow-up date:</strong> Not set
                    </div>
                }
            </div>
        </div>
    }
}

<details class="mt-4">
    <summary><strong>Debug: Deserialization Details (temporary)</strong></summary>
    <div class="mt-2">
        @if (!guideDebug.Any())
        {
            <p class="text-muted">No debug entries.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-bordered">
                    <thead>
                        <tr>
                            <th>GuideId</th>
                            <th>StudentId</th>
                            <th>Length</th>
                            <th>Format</th>
                            <th>Success</th>
                            <th>Error</th>
                            <th>Raw Preview</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dbg in guideDebug)
                        {
                            <tr>
                                <td>@dbg.GuideId</td>
                                <td>@dbg.StudentId</td>
                                <td>@dbg.ContentLength</td>
                                <td>@dbg.FormatUsed</td>
                                <td>@dbg.DeserializationSucceeded</td>
                                <td>@(string.IsNullOrWhiteSpace(dbg.ErrorMessage) ? "-" : dbg.ErrorMessage)</td>
                                <td><code>@dbg.RawContentPreview</code></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</details>
