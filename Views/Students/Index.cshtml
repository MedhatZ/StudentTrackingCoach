@model IEnumerable<StudentTrackingCoach.Models.ViewModels.StudentListViewModel>

@{
    ViewData["Title"] = "Students";
    var pagination = ViewBag.Pagination as StudentTrackingCoach.Models.ViewModels.PaginationViewModel;
    var selectedPageSize = (int?)ViewBag.PageSize ?? 20;
    var startRecord = pagination != null && pagination.TotalCount > 0
        ? ((pagination.PageNumber - 1) * pagination.PageSize) + 1
        : 0;
    var endRecord = pagination != null && pagination.TotalCount > 0
        ? Math.Min(pagination.PageNumber * pagination.PageSize, pagination.TotalCount)
        : 0;
}

<h2 class="mb-4">Students</h2>

<!-- 🔎 RISK FILTER CONTROLS -->
<div class="mb-3">
    <a asp-action="Index"
       asp-route-pageSize="@selectedPageSize"
       class="btn btn-outline-secondary me-2 @(ViewBag.HighRiskOnly == true ? "" : "active")">
        Show All
    </a>

    <a asp-action="Index"
       asp-route-highRiskOnly="true"
       asp-route-pageSize="@selectedPageSize"
       class="btn btn-outline-danger @(ViewBag.HighRiskOnly == true ? "active" : "")">
        High Risk Only
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="text-muted">
                Showing @startRecord-@endRecord of @(pagination?.TotalCount ?? 0) students
            </div>
            <form method="get" asp-action="Index" class="d-flex align-items-center gap-2">
                <input type="hidden" name="highRiskOnly" value="@ViewBag.HighRiskOnly" />
                <label for="pageSize" class="form-label mb-0">Page size</label>
                <select id="pageSize" name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
                    @if (selectedPageSize == 10)
                    {
                        <option value="10" selected>10</option>
                    }
                    else
                    {
                        <option value="10">10</option>
                    }
                    @if (selectedPageSize == 20)
                    {
                        <option value="20" selected>20</option>
                    }
                    else
                    {
                        <option value="20">20</option>
                    }
                    @if (selectedPageSize == 50)
                    {
                        <option value="50" selected>50</option>
                    }
                    else
                    {
                        <option value="50">50</option>
                    }
                    @if (selectedPageSize == 100)
                    {
                        <option value="100" selected>100</option>
                    }
                    else
                    {
                        <option value="100">100</option>
                    }
                </select>
            </form>
        </div>

        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Risk</th>
                    <th>Student ID</th>
                    <th>Status</th>
                    <th>First Gen</th>
                    <th>Working</th>
                    <th>Modality</th>
                    <th>Created</th>
                    <th>Actions</th> <!-- ✅ NEW COLUMN -->
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model)
                {
                    string riskLabel;
                    string riskClass;

                    switch (student.RiskPriority)
                    {
                        case 1:
                            riskLabel = "High";
                            riskClass = "bg-danger";
                            break;
                        case 2:
                            riskLabel = "Medium";
                            riskClass = "bg-warning text-dark";
                            break;
                        default:
                            riskLabel = "Low";
                            riskClass = "bg-success";
                            break;
                    }

                <tr>
                    <td>
                        <span class="badge @riskClass">@riskLabel</span>
                    </td>

                    <td>@student.StudentId</td>
                    <td>@student.EnrollmentStatus</td>

                    <td>
                        @(student.IsFirstGen == true ? "Yes"
                                                : student.IsFirstGen == false ? "No"
                                                : "Unknown")
                        </td>

                        <td>
                            @(student.IsWorking == true ? "Yes"
                                                    : student.IsWorking == false ? "No"
                                                    : "Unknown")
                        </td>

                        <td>@student.PreferredModality</td>

                        <td>
                            @(student.CreatedAt.HasValue
                                                    ? student.CreatedAt.Value.ToString("MM/dd/yyyy")
                                                    : "N/A")
                        </td>

                        <!-- ✅ NEW BUTTON -->
                        <td>
                            <a asp-controller="Students"
                               asp-action="RecommendedStudyGuide"
                               asp-route-id="@student.StudentId"
                               class="btn btn-sm btn-primary">
                                Study Guide
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @await Html.PartialAsync("_Pagination", pagination, new ViewDataDictionary(ViewData)
        {
            ["RouteValues"] = new Dictionary<string, object?>
            {
                ["highRiskOnly"] = ViewBag.HighRiskOnly
            }
        })
    </div>
</div>
