@model StudentTrackingCoach.Models.ViewModels.RecommendedStudyGuideViewModel

@{
    ViewData["Title"] = "Recommended Study Guide";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Recommended Study Guide</h5>
        </div>

        <div class="card-body">
            <form asp-action="SaveStudyGuide" method="post">

                <input type="hidden" asp-for="StudentId" />
                <input type="hidden" asp-for="GeneratedBy" />
                <input type="hidden" asp-for="GeneratedAt" />
                <input type="hidden" asp-for="ConfidenceScore" />
                <input type="hidden" asp-for="IsAIGenerated" />
                <input type="hidden" asp-for="AdvisorModified" />

                @{
                    // Determine risk level from data
                    var riskLevel = ViewBag.RiskLevel ?? "Low";
                    var riskClass = riskLevel == "High" ? "bg-danger" :
                                    riskLevel == "Medium" ? "bg-warning" : "bg-success";
                }

                <!-- Risk Banner -->
                <div class="alert @(riskLevel == "High" ? "alert-danger" :
                                    riskLevel == "Medium" ? "alert-warning" : "alert-info") mb-4">
                    <strong>Risk Level: @riskLevel</strong> -
                    This study guide is personalized based on current academic standing.
                </div>

                @if (ViewBag.AIGenerated == true)
                {
                    <div class="alert alert-primary mb-4">
                        <strong>🤖 AI-Generated Recommendation</strong>
                    </div>
                }

                <div class="alert alert-light border mb-4">
                    <strong>Recommendation Source:</strong> @Model.GeneratedBy
                    @if (Model.GeneratedAt.HasValue)
                    {
                        <span class="ms-2 text-muted">(@Model.GeneratedAt.Value.ToLocalTime().ToString("MM/dd/yyyy HH:mm"))</span>
                    }
                    @if (ViewBag.ShowConfidenceScore == true && Model.ConfidenceScore.HasValue)
                    {
                        <span class="ms-2 badge bg-secondary">Confidence: @((Model.ConfidenceScore.Value * 100).ToString("0"))%</span>
                    }
                </div>

                <!-- Risk Drivers Summary -->
                <div class="card bg-light mb-4">
                    <div class="card-body">
                        <h6 class="card-title">Why this student needs support:</h6>
                        <ul class="mb-0">
                            @if (ViewBag.RiskDrivers != null)
                            {
                                foreach (var driver in ViewBag.RiskDrivers)
                                {
                                    <li>@driver</li>
                                }
                            }
                            else
                            {
                                <li>Risk factors identified</li>
                            }
                        </ul>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Student Name</label>
                        <input asp-for="StudentName" class="form-control" readonly />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Course</label>
                        <input asp-for="CourseName" class="form-control" readonly />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Current Grade</label>
                        <input asp-for="CurrentGrade" class="form-control text-danger fw-bold" readonly />
                    </div>
                </div>

                <hr />

                <!-- Focus Areas - make it readonly since it's AI-generated -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Primary Areas to Focus On</label>
                    <textarea asp-for="FocusAreas" class="form-control" rows="3" readonly></textarea>
                    <small class="text-muted">Generated based on risk factors</small>
                </div>

                <!-- Study Schedule - editable by advisor -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Recommended Weekly Study Schedule</label>
                    <textarea asp-for="StudySchedule" class="form-control" rows="3"></textarea>
                </div>

                <!-- Study Techniques - editable -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Study Techniques</label>
                    <textarea asp-for="StudyTechniques" class="form-control" rows="3"></textarea>
                </div>

                <!-- Resources - editable -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Recommended Resources</label>
                    <textarea asp-for="Resources" class="form-control" rows="3"></textarea>
                </div>

                <!-- Advisor Notes - show from database -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Recent Advisor Notes</label>
                    <textarea asp-for="AdvisorNotes" class="form-control bg-light" rows="3" readonly></textarea>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label">Follow-Up Date</label>
                        <input asp-for="FollowUpDate" type="date" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Expected Outcome</label>
                        <input asp-for="ExpectedOutcome" class="form-control" />
                    </div>
                </div>

                <div class="d-flex justify-content-end">
                    <a asp-action="Details" asp-route-id="@Model.StudentId" class="btn btn-secondary me-2">
                        Cancel
                    </a>
                    <button type="submit" class="btn btn-success">
                        Save Study Guide
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

