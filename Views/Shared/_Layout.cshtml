@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Grad Path</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #e2e8f0;
            margin: 0;
        }

        .sidebar {
            width: 260px;
            height: 100vh;
            background: #0d1b2a;
            color: #ffffff;
            position: fixed;
            top: 0;
            left: 0;
            padding: 20px;
            z-index: 10;
            overflow-y: auto;
        }

        .sidebar h4 {
            font-weight: 600;
            margin-bottom: 30px;
            color: white;
        }

        .sidebar a {
            display: block;
            color: #cbd5e1;
            text-decoration: none;
            padding: 10px 12px;
            border-radius: 6px;
            margin-bottom: 4px;
            transition: all 0.2s;
        }

        .sidebar a:hover {
            background: #1b263b;
            color: #ffffff;
        }

        .sidebar .menu-section {
            margin-top: 20px;
            margin-bottom: 10px;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #6c757d;
            padding-left: 12px;
        }

        .app-frame {
            margin-left: 260px;
            min-height: 100vh;
            background-color: #f8fafc;
        }

        .topbar {
            background: #ffffff;
            padding: 12px 25px;
            border-radius: 0;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .user-name {
            font-weight: 500;
            color: #0d1b2a;
        }

        .logout-btn {
            background: none;
            border: 1px solid #dc3545;
            color: #dc3545;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.2s;
        }

        .logout-btn:hover {
            background: #dc3545;
            color: white;
        }

        .main {
            padding: 30px;
        }
    </style>
</head>

<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <h4>Grad Path</h4>

        <div class="menu-section">MAIN</div>
        <a asp-controller="Home" asp-action="Index">📊 Dashboard</a>
        <a asp-controller="Students" asp-action="MyGradPath">🎓 My Grad Path</a>
        
        <div class="menu-section">STUDENTS</div>
        <a asp-controller="Students" asp-action="Index">👥 All Students</a>
        <a asp-controller="Advisor" asp-action="Index">📋 Advisor View</a>
        
        <div class="menu-section">TASKS & REVIEWS</div>
        <a asp-controller="Tasks" asp-action="Index">✅ Tasks</a>
        <a asp-controller="Advisor" asp-action="PendingReviews">⏳ Pending Reviews</a>
        <a asp-controller="Students" asp-action="MyStudyGuides">📚 My Study Guides</a>

        @if (User.IsInRole("Admin"))
        {
            <div class="menu-section">ADMIN</div>
            <a asp-controller="Admin" asp-action="Users">👤 Manage Users</a>
            <a asp-controller="Admin" asp-action="DataQuality">📊 Data Quality</a>
        }
    </div>

    <!-- App Frame -->
    <div class="app-frame">
        <!-- Top Bar with User Info and Logout -->
        <div class="topbar">
            <h5 class="mb-0">@ViewData["Title"]</h5>
            
            <div class="user-info">
                @if (SignInManager.IsSignedIn(User))
                {
                    <span class="user-name">
                        👋 @User.Identity?.Name
                    </span>
                    <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="m-0">
                        <button type="submit" class="logout-btn">
                            Logout
                        </button>
                    </form>
                }
                else
                {
                    <a class="btn btn-primary btn-sm" asp-area="Identity" asp-page="/Account/Login">
                        Login
                    </a>
                }
            </div>
        </div>

        <!-- Main Content -->
        <div class="main">
            @RenderBody()
        </div>
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>
