            <div class="card-body">
                <h6>Open Tasks</h6>
                <h3>37</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6>Graduation Risk %</h6>
                <h3 class="text-warning">16%</h3>
            </div>
        </div>
