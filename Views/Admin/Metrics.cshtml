@{
    ViewData["Title"] = "Admin Metrics";
}

<h2 class="mb-4">Admin Metrics</h2>

<div class="row">
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6>Total Students</h6>
                <h3>500</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6>High-Risk Students</h6>
                <h3 class="text-danger">82</h3>
            </div>
        </div>
