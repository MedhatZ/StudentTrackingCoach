@model StudentTrackingCoach.Models.ViewModels.AdminCreateUserViewModel

@{
    ViewData["Title"] = "Create User";
}

<h2>Create User</h2>

<form asp-action="CreateUser" method="post">
    <div>
        <label>Email</label><br />
        <input asp-for="Email" />
        <span asp-validation-for="Email" style="color:red"></span>
    </div>

    <div>
        <label>User Name</label><br />
        <input asp-for="UserName" />
        <span asp-validation-for="UserName" style="color:red"></span>
    </div>

    <div>
        <label>Temporary Password</label><br />
        <input asp-for="TemporaryPassword" type="password" />
        <span asp-validation-for="TemporaryPassword" style="color:red"></span>
    </div>

    <div>
        <label>Role</label><br />
        <select asp-for="Role">
            <option value="">-- Select Role --</option>
            @foreach (var role in Model.AvailableRoles)
            {
                <option value="@role">@role</option>
            }
        </select>
        <span asp-validation-for="Role" style="color:red"></span>
    </div>

    <hr />

    <div>
        <label>StudentId (optional)</label><br />
        <input asp-for="StudentId" />
    </div>

    <div>
        <label>AdvisorId (optional)</label><br />
        <input asp-for="AdvisorId" />
    </div>

    <br />

    <button type="submit">Create User</button>
    <a href="/Admin/Users">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
